<nodeDefs>

  <!-- Controller Node -->
  <nodeDef id="access_controller" nodeType="139" nls="access_controller">
    <sts>
      <st id="ST" editor="E_STATUS"/>
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="DISCOVER"/>
        <cmd id="SET_GRP_POLICY">
          <p id="group" editor="E_GROUP"/>
          <p id="policy" editor="E_POLICY"/>
        </cmd>
        <cmd id="SET_USR_POLICY">
          <p id="user" editor="E_AUTH_USER"/>
          <p id="policy" editor="E_POLICY"/>
        </cmd>
      </accepts>
    </cmds>
  </nodeDef>

  <!-- Door Node -->
  <nodeDef id="access_door" nodeType="139" nls="access_door">
    <sts>
      <st id="ST"  editor="E_STATUS"/>   <!-- Door open -->
      <st id="GV1" editor="E_STATUS"/>   <!-- Locked -->
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="UNLOCK"/>
      </accepts>
    </cmds>
  </nodeDef>

  <!-- Reader / Doorbell Node -->
  <nodeDef id="access_reader" nodeType="139" nls="access_reader">
    <sts>
      <st id="ST"  editor="E_STATUS"/>      <!-- Doorbell ring (pulse) -->
      <st id="GV1" editor="E_AUTH_USER"/>   <!-- Last user -->
      <st id="GV2" editor="E_AUTH_METHOD"/> <!-- Auth method -->
      <st id="GV3" editor="E_STATUS"/>      <!-- Access granted (pulse) -->
      <st id="GV4" editor="E_STATUS"/>      <!-- Access denied (pulse) -->
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
      </accepts>
    </cmds>
  </nodeDef>

</nodeDefs>
