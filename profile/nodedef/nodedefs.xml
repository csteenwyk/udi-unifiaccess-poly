<nodeDefs>

  <!-- Controller Node -->
  <nodeDef id="access_controller" nodeType="139" nls="access_controller">
    <sts>
      <st id="ST" editor="E_STATUS"/>
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="DISCOVER"/>
      </accepts>
    </cmds>
  </nodeDef>

  <!-- Door Node -->
  <nodeDef id="access_door" nodeType="139" nls="access_door">
    <sts>
      <st id="ST"  editor="E_STATUS"/>  <!-- Door open -->
      <st id="GV1" editor="E_STATUS"/>  <!-- Locked -->
      <st id="GV2" editor="E_STATUS"/>  <!-- Last access granted -->
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="UNLOCK"/>
      </accepts>
    </cmds>
  </nodeDef>

</nodeDefs>
